# === Paths ===
# Where forge stores heavy data: models, videos, vault, checkpoints, mlflow
# artifacts. Must be on a big disk (on my box this is a ZFS pool across two
# HDDs — steam).
STORAGE_ROOT=/mnt/steam/forge

# === Domain and auth ===
# This email is registered with Let's Encrypt when certificates are issued.
ACME_EMAIL=you@example.com

# Basic auth for everything exposed publicly via caddy (jupyter, mlflow).
# HASH is a bcrypt hash of the password; generate with:
#   docker run --rm caddy:2 caddy hash-password --plaintext '<password>'
# Dollar signs must be doubled in .env (docker compose does variable
# substitution).
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=$$2a$$14$$replace_me_with_bcrypt_hash

# Public domains of the services (DNS must point at this host).
JUPYTER_RL_2048_DOMAIN=jupyter-rl-2048.example.com
JUPYTER_KURPATOV_WIKI_DOMAIN=jupyter-kurpatov-wiki.example.com
MLFLOW_DOMAIN=mlflow.example.com

# Password that containers use to write to mlflow (basic auth).
# Typically the same as what Caddy serves, but can be different.
MLFLOW_TRACKING_PASSWORD=change-me

# === GPU UUIDs ===
# List with:  nvidia-smi -L
# Example:    GPU 0: NVIDIA ... (UUID: GPU-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
GPU_BLACKWELL_UUID=GPU-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GPU_RTX5090_UUID=GPU-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === GPU allocation per task ===
# rl-2048 and kurpatov-wiki must sit on different GPUs, otherwise the
# second one will not get any memory.
RL_2048_GPU_UUID=${GPU_BLACKWELL_UUID}
KURPATOV_WIKI_GPU_UUID=${GPU_RTX5090_UUID}

# === Inference subsystem (vLLM) ===
# inference and rl-2048 are mutually exclusive on the Blackwell — forge has
# two modes for now: inference mode (this is up, rl-2048 is down) or 2048
# mode (rl-2048 is up, this is down). See inference/SPEC.md and
# inference/docs/adr/0001-vllm-public-openai-compatible-endpoint.md.
INFERENCE_DOMAIN=inference.example.com
INFERENCE_GPU_UUID=${GPU_BLACKWELL_UUID}

# OpenAI-compatible API key the served vLLM endpoint will require in
# `Authorization: Bearer ...`. Generate with: openssl rand -hex 32
VLLM_API_KEY=sk-replace-with-strong-random-key

# Model + serving config. Default is Qwen3-32B AWQ-INT4 weights + FP8 KV
# cache (~20 GB on the 96 GB Blackwell, leaves headroom for big context
# and concurrent requests). Qwen3-72B-Instruct-AWQ does not exist on HF
# from the Qwen org as of 2026-04 — community quants are GGUF-only and not
# vLLM-loadable. TurboQuant K4V4 is the eventual KV cache target but only
# in vLLM nightlies as of 2026-04; FP8 is the stable default.
INFERENCE_MODEL=Qwen/Qwen3-32B-AWQ
INFERENCE_SERVED_NAME=qwen3-32b
INFERENCE_MAX_MODEL_LEN=65536

# Optional: HuggingFace token, only needed if INFERENCE_MODEL is gated.
HF_TOKEN=
