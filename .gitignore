# --- secrets ---
.env
*.env
!.env.example
*.pem
*.key
certs/

# --- data (everything that lives on STORAGE_ROOT) ---
# Lives outside the repo (on /mnt/steam/forge), but guard anyway.
mlflow/data/
vault/
models/
videos/
checkpoints/
mlruns/
wandb/

# --- Python / Jupyter ---
__pycache__/
*.pyc
*.pyo
*.ipynb
.ipynb_checkpoints/
.venv/
venv/
*.egg-info/

# whitelist: the one notebook we actually ship
!rl-2048/notebooks/
!rl-2048/notebooks/2048_gpt_oss_20b.ipynb

# --- node / editors ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Docker ---
# compose writes these when you make local-only overrides
docker-compose.override.yml

# --- logs / temporary ---
*.log
tmp/
.tmp/

# --- rl-2048 working clutter ---
# experimental Dockerfile variants pile up next to the live one
rl-2048/Dockerfile-*
rl-2048/Dockerfile.*
!rl-2048/Dockerfile
rl-2048/Caddyfile
rl-2048/hello.py
rl-2048/.aider.chat.history.md
# GRPO/test run outputs (sit next to the notebook during training)
rl-2048/gpu-*/
rl-2048/grpo_*/
rl-2048/mlflow-data/
rl-2048/mlruns/
rl-2048/outputs/
rl-2048/.inductor_cache/
rl-2048/.triton_cache/
rl-2048/.vllm_cache/
