mlflow/data/
vault/
models/
videos/
checkpoints/
mlruns/
wandb/

# --- Python / Jupyter ---
__pycache__/
*.pyc
*.pyo
*.ipynb
.ipynb_checkpoints/
.venv/
venv/
*.egg-info/

# whitelist: the one notebook we actually ship
!rl-2048/notebooks/
!rl-2048/notebooks/2048_gpt_oss_20b.ipynb

# --- node / editors ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Docker ---
# compose writes these when you make local-only overrides
docker-compose.override.yml

# --- logs / temporary ---
*.log
tmp/
.tmp/

# --- rl-2048 working clutter ---
# experimental Dockerfile variants pile up next to the live one
