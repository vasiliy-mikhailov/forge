# === Storage ===
# All bench artifacts (events.jsonl, summary.json, bench-report.md)
# land here. Matches forge's STORAGE_ROOT convention.
STORAGE_ROOT=/mnt/steam/forge

# === Endpoint ===
# vLLM exposed by forge/inference/ behind caddy.
INFERENCE_BASE_URL=https://inference.mikhailov.tech/v1
VLLM_API_KEY=sk-replace-with-the-key-from-forge.env
INFERENCE_SERVED_NAME=qwen3.6-27b

# === OpenHands version ===
# This pins both the local CLI binary that gets baked into the
# image AND the image tag we build/run. Bumping it requires:
#   1. curl the new bin/openhands from
#      https://github.com/OpenHands/OpenHands-CLI/releases
#   2. make build         # rebuilds image with new binary
#   3. make bench         # smoke
OPENHANDS_VERSION=1.17.0

# === Repos the agent will git-clone+push (HTTPS via gh token) ===
WIKI_REPO_URL=https://github.com/vasiliy-mikhailov/kurpatov-wiki-wiki.git
RAW_REPO_URL=https://github.com/vasiliy-mikhailov/kurpatov-wiki-raw.git

# === Sandbox resource limits ===
# Adjust if a run dies on OOM or hits the pid cap.
SANDBOX_MEMORY=16g
SANDBOX_CPUS=4
SANDBOX_PIDS=256
